PUBLIC_NAME=Thrive
DESCRIPTION="Thrive is a tool for life planning"
UNIVERSE=dev
ENV=local
INSTANCE=TO-FILL
VERSION=1.3.2
BUNDLE_ID=io.jupiter.app
GLOBAL_HOSTED_INFRA_ROOT=onrender.com
HOSTED_GLOBAL_WEBUI_URL=https://app.get-thriving.com
HOSTED_GLOBAL_WEBAPI_URL=https://webapi.infra.get-thriving.com
HOSTED_GLOBAL_API_URL=https://api.get-thriving.com
HOSTED_GLOBAL_MCP_URL=https://mcp.get-thriving.com
COMMUNITY_URL=https://discord.gg/Y6PS7ZZ976
APPS_STORAGE_URL=https://github.com/get-thriving/thrive/releases/download/
MAC_STORE_URL=https://apps.apple.com/ro/app/bestcat-the-game/id6738962220?mt=12
APP_STORE_URL=https://apps.apple.com/ro/app/thrive-life-planning/id6739754399
GOOGLE_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=io.jupiter.app
TERMS_OF_SERVICE_URL=https://get-thriving.com/terms-conditions
PRIVACY_POLICY_URL=https://get-thriving.com/privacy-policy
AUTHOR="Mike Bestcat"
COPYRIGHT="2026 Mike Bestcat"
# Backend blend (ADR 0008); dev universe uses local-first defaults.
WEBAPI_STORAGE_ENGINE=sqlite
WEBAPI_TELEMETRY=local
WEBAPI_SEARCH=sql
WEBAPI_CRM=noop
# Postgres Docker image tag for dev PM2 sidecar and compose (not WebAPI app config).
POSTGRES_VERSION=18